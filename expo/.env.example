# RevenueCat public SDK keys — safe to commit, safe to share (public keys).
# Get these from https://app.revenuecat.com → Project settings → Apps
#
# Android is required for Play Store IAP.
# iOS is optional until you sign up for the Apple Developer Program.

EXPO_PUBLIC_RC_ANDROID_KEY=goog_your_android_public_key
EXPO_PUBLIC_RC_IOS_KEY=appl_your_ios_public_key
