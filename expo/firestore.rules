rules_version = '2';

// Hmong Date — Firestore security rules
//
// Deploy steps (no CLI required):
//   1. Open Firebase Console → Firestore Database → Rules tab
//   2. Replace the entire ruleset with the contents of this file
//   3. Click "Publish"
//
// Or via CLI: firebase deploy --only firestore:rules
//
// Schema covered:
//   /users/{uid}                        — profile docs
//   /users/{uid}/swipes/{otherUid}      — swipe history (owner-only)
//   /matches/{matchId}                  — mutual-like match docs (participants-only)
//   /matches/{matchId}/messages/{msgId} — chat messages (participants-only)

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the authed user one of the participants in this match?
    function isMatchParticipant(matchId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/matches/$(matchId))
        && get(/databases/$(database)/documents/matches/$(matchId))
              .data.userIds.hasAny([request.auth.uid]);
    }

    // -------- Users (profiles) --------
    match /users/{uid} {
      // Any signed-in user can read profiles (Discover feed, chat avatars, etc.)
      allow read: if request.auth != null;
      // Only the owner can create / update / delete their own profile
      allow create, update, delete: if request.auth != null && request.auth.uid == uid;

      // Swipes subcollection — owner-only
      // Note: when checking for a mutual like, the OTHER user's swipe is read via
      // the recordSwipe() flow. To allow that read we relax read on swipes to any
      // signed-in user (write stays owner-only).
      match /swipes/{otherUid} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // -------- Matches --------
    match /matches/{matchId} {
      // Any signed-in user can create a match doc, but the resource MUST include
      // their uid in userIds (prevents creating matches for other people).
      allow create: if request.auth != null
                    && request.resource.data.userIds is list
                    && request.resource.data.userIds.hasAny([request.auth.uid]);
      // Read & update & delete: must be a participant
      allow read, update, delete: if request.auth != null
                                  && resource.data.userIds.hasAny([request.auth.uid]);

      // -------- Messages (chat) --------
      match /messages/{messageId} {
        // Participants of the parent match can read all messages
        allow read: if isMatchParticipant(matchId);

        // Participants can create a message ONLY if senderId == their own uid
        // Participants can create a message. Two allowed shapes:
        //   1) Normal: senderId == auth.uid
        //   2) Bot reply: senderId is a "seed-*" account that's also a participant
        //      of this match. Used by the in-app auto-reply tester. Strictly
        //      scoped: the only user that can write a bot message is the human
        //      participant in that match.
        allow create: if isMatchParticipant(matchId)
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 2000
                      && (
                        request.resource.data.senderId == request.auth.uid
                        || (
                          request.resource.data.senderId is string
                          && request.resource.data.senderId.matches("^seed-.*")
                          && get(/databases/$(database)/documents/matches/$(matchId))
                                .data.userIds.hasAny([request.resource.data.senderId])
                        )
                      );

        // Participants can update messages — used for read receipts (arrayUnion on readBy).
        // We don't restrict the diff here to keep things simple; messages aren't editable
        // from the UI anyway.
        allow update: if isMatchParticipant(matchId);

        // No deletes from clients
        allow delete: if false;
      }
    }

    // -------- Reports (user-submitted abuse / bug reports) --------
    match /reports/{reportId} {
      // Any signed-in user can create a report. Their uid must be in the doc.
      allow create: if request.auth != null
                    && request.resource.data.reporterUid == request.auth.uid;
      // Read/update/delete only by reporter (admins use Firebase Console / Admin SDK)
      allow read, update, delete: if request.auth != null
                                  && resource.data.reporterUid == request.auth.uid;
    }
  }
}
